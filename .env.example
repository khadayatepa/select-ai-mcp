# OpenAI key — stored as a database credential for Select AI (the DB calls the LLM)
OPENAI_API_KEY=sk-...
SELECT_AI_MODEL=gpt-4o

# SQLcl MCP saved connection to your Oracle 26ai Autonomous Database
#   sql /nolog ; conn -save DEBATE -savepwd <user>@<adb-tns-alias>
ORACLE_MCP_CONNECTION=DEBATE
SQLCL_COMMAND=sql

# The natural-language question to ask
QUESTION=What are the total sales by region?
